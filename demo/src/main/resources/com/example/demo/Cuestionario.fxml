<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.CuestionarioController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label text="CUESTIONARIO DE PROGRAMACION" />

    <Label text="1. ¿Que lenguaje se utiliza para crear aplicaciones JavaFX?" />
    <ComboBox fx:id="cmb1" />

    <Label text="2. ¿Cual es una estructura de repeticion?" />
    <ComboBox fx:id="cmb2" />

    <Label text="3. ¿Que símbolo termina una instrucción en Java?" />
    <ComboBox fx:id="cmb3" />

    <Label text="4. ¿Cual es el metodo principal de un programa Java?" />
    <ComboBox fx:id="cmb4" />

    <Button onAction="#calcular" text="Calcular Puntaje" />

    <Label fx:id="lblResultado" />

</VBox>
