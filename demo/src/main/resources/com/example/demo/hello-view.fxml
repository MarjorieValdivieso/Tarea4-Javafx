<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="153.0" prefWidth="274.0"
      spacing="20.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo.HelloController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="lblLogin" text="LOGIN" />

    <Label fx:id="lblUsuario" text="Usuario" />
    <TextField fx:id="txtUsuario" />

    <Label fx:id="lblContrasenia" text="Contraseña" />
    <PasswordField fx:id="txtContrasenia" />

    <Label fx:id="lblRol" text="Rol" />
    <ComboBox fx:id="txtRol" prefWidth="150.0" />

    <Label fx:id="welcomeText" />

    <Button fx:id="btnIngresar"
            text="Ingresar"
            onAction="#ingresar" />

    <Button fx:id="btnSalir"
            text="Salir"
            onAction="#salir" />

</VBox>